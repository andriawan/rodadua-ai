APP_NAME=rodaduaAI
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.rodadua.ai

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

FRONTEND_URL=https://rodadua.ai

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rodadua
DB_USERNAME=rodadua
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.rodadua.ai

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@rodadua.ai"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

AI_PROVIDER=openai
OPENAI_API_KEY=
DEEPSEK_API_KEY=

SANCTUM_STATEFUL_DOMAINS=rodadua.ai,www.rodadua.ai
CORS_ALLOWED_ORIGINS=https://rodadua.ai,https://www.rodadua.ai

# Error Monitoring (install sentry/sentry-laravel to enable)
SENTRY_DSN=
SENTRY_LARAVEL_DSN=

